[gd_scene load_steps=7 format=3]

; Inheritable enemy template: the standard component tree (Health/Movement/AI/Protection/HealthBar +
; CollisionShape + Visual). New archetypes inherit this and override visual/stats/AI params,
; so they don't re-declare the whole tree. (The original Goblin/Sniper/Golem predate this.)
; ProtectionComponent defaults to 0 DR (inert) but lets a Shield-Bot Cleric's aura buff the mob.

[ext_resource type="Script" path="res://components/HealthComponent.gd" id="1_health"]
[ext_resource type="Script" path="res://components/MovementComponent.gd" id="2_move"]
[ext_resource type="Script" path="res://components/AIComponent.gd" id="3_ai"]
[ext_resource type="Script" path="res://components/HealthBar.gd" id="4_hb"]
[ext_resource type="Script" path="res://components/ProtectionComponent.gd" id="5_prot"]

[sub_resource type="CircleShape2D" id="cs_base"]
radius = 14.0

[node name="BaseEnemy" type="CharacterBody2D" groups=["enemies"]]

[node name="Visual" type="Polygon2D" parent="."]
color = Color(0.8, 0.4, 0.4, 1)
polygon = PackedVector2Array(-14, -14, 14, -14, 14, 14, -14, 14)

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("cs_base")

[node name="HealthComponent" type="Node2D" parent="."]
script = ExtResource("1_health")
configured_hearts = 1.0
xp_reward = 20

[node name="MovementComponent" type="Node2D" parent="."]
script = ExtResource("2_move")

[node name="ProtectionComponent" type="Node2D" parent="."]
script = ExtResource("5_prot")

[node name="AIComponent" type="Node2D" parent="."]
script = ExtResource("3_ai")

[node name="HealthBar" type="Node2D" parent="."]
script = ExtResource("4_hb")
width = 34.0
y_offset = -26.0

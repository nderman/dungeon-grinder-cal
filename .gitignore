# --- Godot 4 (project lives in game-client/) ---
game-client/.godot/
game-client/.import/
game-client/export.cfg
# export_presets.cfg is normally ignored (it can hold signing secrets) — ours is committed on purpose
# (Web preset, no secrets; the PostHog key is injected separately at build time and stays gitignored).
!game-client/export_presets.cfg
*.translation

# --- Raw art / audio source files: tracked via Git LFS only, never bulk-committed ---
# /assets-raw holds PSDs, uncompressed audio, etc. Export optimized assets into
# game-client/assets/ instead. Large binaries go through LFS (see .gitattributes).
assets-raw/**
!assets-raw/.gitkeep

# --- Secrets / local config: never commit (keys, tokens, signing creds) ---
.env
.env.*
!.env.example
*.secret
secrets.cfg
posthog.key          # PostHog key bundled into web/exported builds — written transiently by CI, never committed

# --- Build output ---
build/
game-client/build/
# Godot mobile signing / store keys
*.keystore
*.jks
*.p12
*.mobileprovision

# --- OS / editor junk ---
.DS_Store
Thumbs.db
*~
*.swp
.vscode/
.idea/

# Mono/C# (unused — GDScript only)
.mono/
mono_crash.*.json
